{
    "name": "webcalculator",
    "description": "A calculator app in Node.js",
    "version": "1",
    "scripts": {
        "mocha:test": "mocha tests",
        "nyc:run": "nyc --check-coverage --branches 100 --lines 100 --statements 100 --functions 100 npm run mocha:test",
        "nyc:coverage": "nyc report --reporter=lcov",
        "cypress:run": "cypress run",
        "cypress:test": "start-server-and-test app:serve http://localhost:3000 cypress:run",
        "eslint:check": "eslint --fix index.js modules/*",
        "app:serve": "nodemon",
        "jsdoc": "jsdoc modules/ -d docs"
    },
    "dependencies": {
        "express": "^4.18.2"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.2",
        "babel-jest": "^30.3.0",
        "coveralls": "^3.1.1",
        "cypress": "^12.17.4",
        "eslint": "^8.57.1",
        "eslint-config-google": "^0.14.0",
        "globals": "^17.4.0",
        "jest": "^30.3.0",
        "jsdoc": "^4.0.2",
        "jslint": "^0.12.1",
        "mocha": "^10.2.0",
        "nodemon": "^2.0.22",
        "nyc": "^15.1.0",
        "start-server-and-test": "^2.0.0"
    }
}
